# POE-INSIGHT Environment Configuration
# Copy this to .env and fill in your values

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://localhost:5432/poe_insight

# Server port (default: 3000)
PORT=3000

# OpenAI API key — required for the AI Analysis toggle
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=
